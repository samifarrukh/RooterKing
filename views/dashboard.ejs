<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owner Dashboard - VALVORO</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #F4F7FB;
        }
        .card-row {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: white;
            border: 1px solid #eef2f6;
        }
        .card-row:hover {
            transform: translateY(-4px) scale(1.005);
            box-shadow: 0 20px 40px -12px rgba(0,0,0,0.06);
            border-color: #cbd5e1;
            z-index: 10;
        }
        .status-pill {
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 1rem 1.5rem;
            border-radius: 1rem;
            width: 100%;
            text-align: center;
        }
        .message-card {
            background: #f8fafc;
            border: 1px solid #eff2f5;
            padding: 1.5rem;
            border-radius: 1.25rem;
            max-height: 120px;
            overflow-y: auto;
            font-style: italic;
            color: #475569;
            line-height: 1.6;
        }
        .plumber-brand-blue { color: #0f4392; }
        .plumber-bg-blue { background-color: #0f4392; }
    </style>
</head>
<body class="bg-[#F4F7FB] text-[#1e293b]">
    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar: Premium Stealth -->
        <aside class="hidden lg:flex flex-col w-50 bg-[#0a0f1d] text-white">
            <div class="p-10 pb-16">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-cyan-400 rounded-2xl flex items-center justify-center text-[#0a0f1d] shadow-lg shadow-cyan-500/20">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    </div>
                    <span class="text-3xl font-black italic tracking-tighter uppercase text-white">VALVORO</span>
                </div>
            </div>

            <nav class="flex-1 px-6 space-y-3">
                <a href="/dashboard" class="flex items-center gap-4 px-6 py-5 bg-white/10 rounded-[1.5rem] text-cyan-400 font-bold border border-white/5 shadow-inner">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    DASHBOARD
                </a>
                <a href="#" class="flex items-center gap-4 px-6 py-5 hover:bg-white/5 rounded-[1.5rem] text-slate-400 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    ORDER HISTORY
                </a>
                <a href="#" class="flex items-center gap-4 px-6 py-5 hover:bg-white/5 rounded-[1.5rem] text-slate-400 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    TEAMS
                </a>
            </nav>

            <div class="p-10 mt-auto">
                <div class="bg-indigo-600 rounded-[2rem] p-8 relative overflow-hidden shadow-2xl shadow-indigo-500/40">
                    <div class="relative z-10">
                        <p class="text-[11px] font-black text-indigo-100 tracking-widest uppercase mb-2">Connected</p>
                        <p class="text-md font-bold text-white uppercase italic">Owner Panel v2.4</p>
                    </div>
                    <div class="absolute -right-8 -bottom-8 w-24 h-24 bg-white/10 rounded-full"></div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Header bar -->
            <header class="h-18 bg-[#0f4392] flex items-center justify-between px-12 text-white relative z-20 shadow-[0_10px_30px_rgba(15,67,146,0.2)]">
                <div class="flex flex-col">
                    <h1 class="text-2xl font-black uppercase italic tracking-tighter leading-none mt-1 mb-2">Live Orders</h1>
                    <div class="flex items-center gap-3">
                        <div class="w-2.5 mb-1 h-2.5 bg-green-400 rounded-full animate-pulse shadow-lg shadow-green-400/50"></div>
                        <p class="text-[10px] mb-1 font-bold text-blue-100 uppercase tracking-widest">Active Monitoring Active</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-6">
                
                    <a href="/login" class="bg-white text-[#0f4392] px-6 py-3 rounded-2xl text-xs font-black uppercase tracking-widest transition-all hover:bg-cyan-50 shadow-xl active:scale-95">
                        Sign Out
                    </a>
                </div>
            </header>

            <!-- Dashboard Content -->
            <div class="flex-1 overflow-y-auto p-12 lg:p-16 space-y-12">
                
                <!-- Quick Stats -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                    <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-blue-200 flex justify-between items-center group  hover:border-blue-500  hover:border-4 transition-colors">
                        <div >
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block">New Enquiries</span>
                            <span class="text-4xl font-black text-[#0f4392] tracking-tighter"><%= booking.filter(b => b.status === 'Pending').length %></span>
                        </div>
                        <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-3xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                    </div>
                    <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-cyan-200 flex justify-between items-center group hover:border-4 hover:border-cyan-500 transition-colors">
                        <div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block">On Site Jobs</span>
                            <span class="text-4xl font-black text-cyan-500 tracking-tighter"><%= booking.filter(b => b.status === 'In Progress').length %></span>
                        </div>
                        <div class="w-16 h-16 bg-cyan-50 text-cyan-600 rounded-3xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        </div>
                    </div>
                    <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-emerald-200 flex justify-between items-center group hover:border-4  hover:border-emerald-500 transition-colors">
                        <div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block">Today Done</span>
                            <span class="text-4xl font-black text-emerald-600 tracking-tighter"><%= booking.filter(b => b.status === 'Done').length %></span>
                        </div>
                        <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-3xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                    </div>
                </div>

                <!-- Card Row List -->
                <div class="space-y-6">
                    <div class="flex items-center justify-between px-6 mb-8">
                        <div>
                            <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase italic">Today's Jobs</h2>
                            <p class="text-slate-400 font-bold uppercase text-[11px] tracking-widest mt-2">Sort by urgency to call customers faster</p>
                        </div>
                        <button onclick="window.location.reload()" class="flex items-center gap-3 px-8 py-4 bg-white text-slate-600 font-black text-xs uppercase tracking-widest rounded-2xl shadow-sm border border-slate-100 hover:bg-slate-50 transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            Refresh Feed
                        </button>
                    </div>

                    <div class="space-y-6">
                        <% booking.forEach(booking => { %>
                            <div class="card-row rounded-[2.5rem] p-10 flex flex-col xl:flex-row items-center gap-12">
                                <!-- CUSTOMER INFO -->
                                <div class="flex items-center gap-8 w-full xl:w-1/4 shrink-0">
                                    
                                    <div class="min-w-0">
                                        <h3 class="text-2xl font-black text-slate-900 tracking-tight leading-none mb-3"><%= booking.name %></h3>
                                        <div class="flex flex-col gap-1.5">
                                            <a href="tel:<%= booking.phone %>" class="flex items-center gap-2 text-blue-600 font-extrabold text-[15px] hover:underline">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5.5A2.5 2.5 0 015.5 3h1.872a2.5 2.5 0 012.428 1.902l.602 2.406a2.5 2.5 0 01-.64 2.21l-1.352 1.352a12.047 12.047 0 005.293 5.293l1.352-1.352a2.5 2.5 0 012.21-.64l2.406.602a2.5 2.5 0 011.902 2.428V18.5a2.5 2.5 0 01-2.5 2.5h-1a15 15 0 01-15-15v-1z" stroke-width="2.5"/></svg>
                                                <%= booking.phone %>
                                            </a>
                                            <span class="text-xs font-extrabold mt-1 uppercase tracking-widest"><%= booking.email %></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- TASK & MESSAGE -->
                                <div class="flex-1 w-full min-w-0">
                                    <div class="flex flex-col gap-4">
                                        <div class="flex items-center gap-4">
                                            <span class="px-5 py-2 bg-[#0f4392] text-white text-[11px] font-black uppercase tracking-[0.15em] rounded-xl whitespace-nowrap">
                                                <%= booking.service %>
                                            </span>
                                            <span class="text-slate-300 font-black">|</span>
                                            <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Customer Reported Issue:</p>
                                        </div>
                                        <div class=" text-black message-card">
                                            "<%= booking.message %>"
                                        </div>
                                    </div>
                                </div>

                                <!-- STATUS & ACTIONS -->
                                <div class="w-full xl:w-72 shrink-0 flex flex-col gap-4">
                                    <form action="/status/<%= booking.id %>" method="POST" class="w-full">
                                        <select name="status" onchange="this.form.submit()" 
                                            class="appearance-none status-pill cursor-pointer border-2 transition-all outline-none focus:ring-8 focus:ring-blue-500/5
                                            <%= booking.status === 'Pending' ? 'bg-amber-50 font-bold text-amber-700 border-amber-200' : '' %>
                                            <%= booking.status === 'In Progress' ? 'bg-blue-50 font-bold text-blue-700 border-blue-200' : '' %>
                                            <%= booking.status === 'Done' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : '' %>">
                                            <option value="Pending" <%= booking.status === 'Pending' ? 'selected' : '' %>>🚨 PENDING / CALL NOW</option>
                                            <option value="In Progress" <%= booking.status === 'In Progress' ? 'selected' : '' %>>🛠 PLUMBER ON SITE</option>
                                            <option value="Done" <%= booking.status === 'Done' ? 'selected' : '' %>>✅ JOB COMPLETED</option>
                                        </select>
                                    </form>
                                    <div class="flex justify-between items-center gap-4">
                                        <button class="flex-1 h-14 bg-slate-50 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-2xl hover:bg-slate-100 transition-colors">
                                            View Logs
                                        </button>
                                        <form action="/delete/<%= booking.id %>" method="POST" onsubmit="return confirm('Archive this request?')" class="shrink-0">
                                            <button type="submit" class="h-14 w-14 bg-red-50 text-red-500 rounded-2xl flex items-center justify-center hover:bg-red-100 transition-all active:scale-90">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                    
                    <% if (booking.length === 0) { %>
                        <div class="h-96 bg-white rounded-[3rem] border border-dashed border-slate-200 flex flex-col items-center justify-center">
                            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-6">
                                <svg class="w-10 h-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                            </div>
                            <p class="text-xl font-black text-slate-200 uppercase tracking-[0.2em] italic">No Orders Found</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
