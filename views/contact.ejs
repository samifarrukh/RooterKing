<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us | VALVORO Plumbing Services</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .bg-gradient-valvoro { background: linear-gradient(135deg, #0f4392 0%, #1e3a8a 100%); }
    .rounded-valvoro { border-radius: 3.5rem; }
    .input-field { 
      background: #f8fafc; 
      border: 2px solid #e2e8f0; 
      border-radius: 1.5rem; 
      padding: 1.25rem 1.5rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    .input-field:focus { 
      border-color: #22d3ee; 
      outline: none; 
      background: white;
      box-shadow: 0 10px 30px rgba(34, 211, 238, 0.1);
    }
  </style>
</head>
<body class="bg-[#f8fafc] text-[#0f172a]">

  <%- include('partials/navbar') %>

  <!-- Header Section -->
  <section class="max-w-[1500px] mx-auto px-4 py-8">
    <div class="bg-gradient-valvoro rounded-valvoro py-24 px-10 text-center text-white relative overflow-hidden">
       <div class="absolute inset-0 opacity-10 pointer-events-none">
          <div class="absolute -top-48 left-1/2 w-[800px] h-[800px] bg-cyan-400 rounded-full blur-[150px] -translate-x-1/2"></div>
       </div>
       <div class="relative z-10">
          <p class="text-[#22d3ee] font-black uppercase tracking-widest text-sm mb-6">Support 24/7</p>
          <h1 class="text-6xl lg:text-8xl font-black tracking-tighter uppercase mb-6">Contact Us.</h1>
          <p class="text-xl font-medium opacity-80 max-w-2xl mx-auto leading-relaxed">
            Reach out for emergencies, quotes, or general enquiries. We respond within 30 minutes.
          </p>
       </div>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="py-24 max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-5 gap-20">
       
       <div class="lg:col-span-3 space-y-12">
          <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-cyan-50 border-2 border-[#22d3ee] p-8 rounded-[2rem] flex items-center gap-6 animate-bounce">
               <div class="w-12 h-12 bg-[#22d3ee] rounded-full flex items-center justify-center text-[#0f172a]">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
               </div>
               <div>
                  <p class="text-xl font-black text-[#0f172a] uppercase">Message Sent!</p>
                  <p class="text-slate-600 font-medium"><%= message %></p>
               </div>
            </div>
          <% } %>
          <div class="space-y-4">
             <h2 class="text-5xl font-black text-[#0f172a] uppercase tracking-tighter">Send a Message</h2>
             <p class="text-slate-500 font-medium text-lg leading-relaxed">Fill out the form below and one of our master plumbers will call you back shortly.</p>
          </div>
          
          <form action="/booking" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
             <div class="space-y-2">
                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-4">Full Name</label>
                <input type="text" name="name" placeholder="John Doe" class="w-full input-field" required>
             </div>
             <div class="space-y-2">
                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-4">Email Address</label>
                <input type="email" name="email" placeholder="john@example.com" class="w-full input-field" required>
             </div>
             <div class="space-y-2">
                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-4">Phone Number</label>
                <input type="tel" name="phone" placeholder="+61 000 000 000" class="w-full input-field" required>
             </div>
             <div class="space-y-2">
                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-4">Service Type</label>
                <select name="service" class="w-full input-field appearance-none">
                   <option>Emergency Plumbing Repair</option>
<option>Drain Cleaning / Clog Removal</option>
<option>Leak Detection & Repair</option>
<option>Pipe Repair / Replacement</option>
<option>Faucet & Sink Installation</option>
<option>Toilet Repair / Installation</option>
<option>Water Heater Repair</option>
<option>Water Heater Installation</option>
<option>Sewer Line Repair</option>
<option>Sump Pump Installation</option>
<option>Bathroom Plumbing</option>
<option>Kitchen Plumbing</option>

<option disabled>──────── HVAC SERVICES ────────</option>

<option>Furnace Repair</option>
<option>Furnace Installation</option>
<option>Boiler Repair</option>
<option>Boiler Installation</option>
<option>Heating System Maintenance</option>
<option>Heat Pump Installation</option>
<option>Heat Pump Repair</option>
<option>Air Conditioning Repair</option>
<option>Air Conditioning Installation</option>
<option>AC Maintenance / Tune-up</option>
<option>Duct Cleaning</option>
<option>Ventilation Repair</option>

<option disabled>──────── OTHER ────────</option>

<option>Inspection / Diagnosis</option>
<option>Maintenance Service</option>
<option>New Construction Plumbing</option>
<option>Renovation Plumbing Work</option>
<option>Other Service</option>
                </select>
             </div>
             <div class="md:col-span-2 space-y-2">
                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-4">Your Message</label>
                <textarea name="message" rows="5" placeholder="Tell us about the issue..." class="w-full input-field resize-none" required></textarea>
             </div>
             <div class="md:col-span-2 pt-4">
                <button type="submit" class="w-full bg-[#0a0f1d] text-white py-6 rounded-[2rem] font-black text-xl hover:bg-[#22d3ee] hover:text-[#0a0f1d] transition-all shadow-2xl flex items-center justify-center gap-4 group">
                   <span>Send Enquiry Now</span>
                   <div class="bg-white/10 group-hover:bg-[#0a0f1d] group-hover:text-white rounded-full p-2 transition-all">
                      <svg class="w-6 h-6 rotate-[-45deg]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                   </div>
                </button>
             </div>
          </form>
       </div>

       <div class="lg:col-span-2 space-y-10">
          <div class="bg-white p-12 rounded-[3.5rem] shadow-xl border border-slate-100 space-y-10 relative overflow-hidden">
             <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-50 rounded-full blur-[80px]"></div>
             
             <div class="relative z-10">
                <h3 class="text-3xl font-black text-[#0f172a] uppercase tracking-tighter mb-8">Direct Contact</h3>
                <div class="space-y-8">
                   <div class="flex items-start gap-6">
                      <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-[#0f4392] shrink-0 shadow-lg shadow-blue-100">
                         <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                      </div>
                      <div>
                         <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Phone Call</p>
                         <p class="text-xl font-black text-[#0f172a] tracking-tight"> <span class="mr-2"> +1   </span> 780-456-8060</p>
                      </div>
                   </div>
                   <div class="flex items-start gap-6">
                      <div class="w-14 h-14 bg-cyan-50 rounded-2xl flex items-center justify-center text-[#0f4392] shrink-0 shadow-lg shadow-cyan-100">
                         <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
                      </div>
                      <div>
                         <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Email Support</p>
                         <p class="text-xl font-black text-[#0f172a] tracking-tight">RooterKing@gamil.com</p>
                      </div>
                   </div>
                   <div class="flex items-start gap-6">
                      <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-[#0f4392] shrink-0 shadow-lg shadow-slate-200">
                         <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                      </div>
                      <div>
                         <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Headquarters</p>
                         <p class="text-xl font-black text-[#0f172a] tracking-tight leading-tight">14415 92 St NW, Edmonton, AB T5E 5V5, Canada</p>
                      </div>
                   </div>
                </div>
                
            <div class="pt-10">
  <div class="w-full h-48 rounded-[2rem] overflow-hidden shadow-lg border border-slate-200">

    <iframe
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d4251.327053125136!2d-113.47925172157944!3d53.606939607614045!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x65fc2158651dd677%3A0xabf46de82f535c62!2sRooter%20King%20Canada!5e1!3m2!1sen!2s!4v1778829525139!5m2!1sen!2s"
      class="w-full h-full"
      style="border:0;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>

  </div>
</div>
             </div>
          </div>
       </div>

    </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
